{
  "expo": {
    "name": "snapRecall",
    "slug": "snaprecall",
    "owner": "sriza",
    "scheme": "snaprecall",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.snaprecall.app",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./app/assets/android-icon-foreground.png",
        "backgroundImage": "./app/assets/android-icon-background.png",
        "monochromeImage": "./app/assets/android-icon-monochrome.png"
      },
      "package": "com.snaprecall.app"
    },
    "web": {
      "favicon": "./app/assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "4abd05f6-de84-45f9-9138-d3aa57cb3d12"
      }
    }
  }
}
